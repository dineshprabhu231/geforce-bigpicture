{
  "name": "gfn-bigpicture",
  "productName": "Big Picture for GeForce NOW",
  "version": "0.1.0",
  "description": "A controller-friendly Big Picture launcher for your GeForce NOW game shortcuts.",
  "private": true,
  "main": "electron/main.js",
  "author": "You",
  "license": "MIT",
  "scripts": {
    "dev:renderer": "vite",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "start": "npm run build:renderer && cross-env NODE_ENV=production electron ."
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.yourname.gfnbigpicture",
    "productName": "Big Picture for GeForce NOW",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "directories": {
      "output": "release"
    }
  }
}
