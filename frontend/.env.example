# Copy to .env only if you need to override the defaults. Neither variable
# is required for local dev — with the backend running on localhost:3000,
# the app finds it automatically.

# Override if your backend isn't on localhost:3000 (e.g. testing against
# your deployed Railway/Vercel URL instead of a local backend).
ARTWORK_SERVER_URL=

# Only needed if you set CLIENT_SECRET on the backend too — must match it
# exactly. Leave blank if the backend is running open (no CLIENT_SECRET set).
ARTWORK_CLIENT_SECRET=
