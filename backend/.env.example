# Copy to .env for local testing (Railway: set these as project variables
# instead — see README.md).

# Required. Get one free at https://www.steamgriddb.com/profile/preferences/api
STEAMGRIDDB_API_KEY=

# Optional. If set, the Electron app must send the same value in an
# `x-app-secret` header (ARTWORK_CLIENT_SECRET) or requests are rejected.
# Leave blank to run the server open.
CLIENT_SECRET=
